# Server
PORT=5000

# PostgreSQL connection string — required for `prisma migrate dev`
# Leave commented to use in-memory auth (no DB needed for signup/login testing)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/assetflow

# Supabase example (Project Settings → Database → Connection string → URI):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT signing secret — change this in production
JWT_SECRET=your-super-secret-jwt-key
